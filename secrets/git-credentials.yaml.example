# =============================================================================
# git-credentials.yaml.example
# =============================================================================
# Ini adalah FILE TEMPLATE - aman untuk di-commit ke Git.
# File aslinya (git-credentials.yaml) ada di .gitignore.
#
# Cara pakai:
# 1. Copy file ini: cp secrets/git-credentials.yaml.example secrets/git-credentials.yaml
# 2. Isi dengan nilai base64 yang asli
# 3. Apply: kubectl apply -f secrets/git-credentials.yaml -n airflow
# =============================================================================

apiVersion: v1
kind: Secret
metadata:
  name: git-credentials
  namespace: airflow
type: Opaque
data:
  GIT_SYNC_USERNAME: <base64_encoded_git_username>
  GIT_SYNC_PASSWORD: <base64_encoded_git_pat>
  GITSYNC_USERNAME: <base64_encoded_git_username>
  GITSYNC_PASSWORD: <base64_encoded_git_pat>
