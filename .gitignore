# =============================================================================
# .gitignore - Apache Airflow Kubernetes Project
# =============================================================================

# !! PENTING: File secrets yang berisi kredensial asli JANGAN dicommit !!
secrets/git-credentials.yaml
secrets/*.yaml
!secrets/git-credentials.yaml.example  # Kecuali file contoh/template

# Backup files dari script
*.bak
*.tmp

# Helm generated files
charts/
Chart.lock

# OS files
.DS_Store
Thumbs.db
*.swp
*~

# Editor
.vscode/
.idea/
*.code-workspace

# Python (jika ada script Python lokal)
__pycache__/
*.pyc
*.pyo
.env
venv/


target/
dbt_packages/
logs/
